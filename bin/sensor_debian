#!/bin/sh

case $1 in
        updates|u)
                apt-get upgrade -s | /usr/bin/grep -P '^\d+ upgraded' | cut -d" " -f1
        ;;
        updates-json|ujson)
                number=$(apt-get upgrade -s | /usr/bin/grep -P '^\d+ upgraded' | cut -d" " -f1)
                packages=$(apt list --upgradeable 2>/dev/null | /usr/bin/grep / | cut -d"/" -f1 | sed ':a;N;$!ba;s/\n/,/g')
                printf '{"number":"%s","packages":"%s"}\n' "$number" "$packages"
        ;;
        updates-pkg|upkg)
                apt list --upgradeable 2>/dev/null | /usr/bin/grep / | cut -d"/" -f1
        ;;
esac
